# ios/Podfile（最终修正版，适配GitHub Actions与Flutter 3.41.6+）
platform :ios, '12.0'  # 最低支持iOS版本（可调整）
use_frameworks!
ENV['COCOAPODS_DISABLE_STATS'] = 'true'  # 禁用CocoaPods统计

# 1. 从环境变量获取Flutter SDK路径（GitHub Actions自动设置）
flutter_root = ENV['FLUTTER_ROOT']
raise "FLUTTER_ROOT未设置，请确保Flutter已正确安装" if flutter_root.nil?

# 2. 引入Flutter官方Podhelper（自动处理依赖与路径）
podhelper_path = File.join(flutter_root, 'packages', 'flutter_tools', 'podhelper.rb')
raise "Podhelper文件未找到：#{podhelper_path}" unless File.exist?(podhelper_path)
require podhelper_path

# 3. 配置Target（Runner）
target 'Runner' do
  use_frameworks!
  use_modular_headers!  # Flutter 3.0+要求

  # 安装Flutter依赖（Podhelper自动处理）
  install_all_flutter_pods(flutter_application_path: flutter_root)
end

# 4. Post-install钩子（处理Flutter编译选项）
post_install do |installer|
  flutter_post_install(installer) if defined?(flutter_post_install)
end
