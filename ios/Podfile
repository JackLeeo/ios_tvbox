source 'https://cdn.cocoapods.org/'

platform :ios, '13.0'

ENV['COCOAPODS_DISABLE_STATS'] = 'true'
# 注释掉这行，否则Git LFS无法拉取NodeMobile的实际框架文件，会导致编译时找不到真实的框架二进制
# ENV['GIT_LFS_SKIP_SMUDGE'] = '1'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcbuild_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcbuild_settings_path)
    raise "#{generated_xcbuild_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcbuild_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcbuild_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      config.build_settings['CODE_SIGNING_REQUIRED'] = 'NO'
      config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
      config.build_settings['CODE_SIGN_IDENTITY'] = ''
      config.build_settings['DEVELOPMENT_TEAM'] = ''
      config.build_settings['OTHER_LDFLAGS'] = '$(inherited) -framework AVFoundation -framework CoreMedia -framework CoreVideo'
    end
  end

  app_project_path = 'Runner.xcodeproj'
  if File.exist?(app_project_path)
    app_project = Xcodeproj::Project.open(app_project_path)
    main_target = app_project.targets.find { |t| t.name == 'Runner' }
    if main_target
      main_target.build_configurations.each do |config|
        config.build_settings['SWIFT_OBJC_BRIDGING_HEADER'] = 'Runner/Runner-Bridging-Header.h'
        # 核心修复：关闭PCH验证，让Clang忽略模块路径的校验，完美解决那个路径错误
        config.build_settings['GCC_NO_VALIDATE_PCH'] = 'YES'
        # 同时允许非确定性模块，彻底绕开路径检查
        config.build_settings['CLANG_ALLOW_NON_DETERMINISTIC_MODULES'] = 'YES'
        # 👇 修复路径！现在是根目录下的Frameworks，所以要往上走两级！
        config.build_settings['FRAMEWORK_SEARCH_PATHS'] = '$(inherited) $(SRCROOT)/../../Frameworks'
        config.build_settings['OTHER_LDFLAGS'] = '$(inherited) -framework NodeMobile'
      end
      app_project.save
    end
  end

  installer.pods_project.build_configurations.each do |config|
    config.build_settings['CODE_SIGNING_REQUIRED'] = 'NO'
    config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
    config.build_settings['CODE_SIGN_IDENTITY'] = ''
    config.build_settings['DEVELOPMENT_TEAM'] = ''
    config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
  end
end
