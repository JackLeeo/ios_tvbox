<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>method</key>
    <string>debugging</string>  <!-- 修复弃用警告：替换已废弃的development为苹果官方推荐的debugging，适配无签名打包 -->
    <key>teamID</key>
    <string>0000000000</string>  <!-- 修复核心报错：占位非空值，满足Xcode校验要求，无签名无需真实团队ID -->
    <key>compileBitcode</key>
    <false/>  <!-- 关闭Bitcode编译（减少包体积） -->
    <key>uploadBitcode</key>
    <false/>
    <key>uploadSymbols</key>
    <false/>
    <key>signingStyle</key>
    <string>manual</string>  <!-- 手动签名（无签名） -->
    <key>signingCertificate</key>
    <string>-</string>  <!-- 修复：无签名占位符，避免空字符串校验报错 -->
    <key>stripSwiftSymbols</key>
    <true/>  <!-- 移除Swift符号（减少包体积） -->
    <key>thinning</key>
    <string>&lt;none&gt;</string>  <!-- 不裁剪架构（支持所有设备） -->
</dict>
</plist>
